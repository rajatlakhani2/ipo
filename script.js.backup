                    </div>
                    <div class="form-group">
                        <label>Listing Date</label>
                        <input type="date" id="ipo-listing-date">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Number of Shares *</label>
                        <input type="number" id="ipo-shares" required>
                    </div>
                    <div class="form-group">
