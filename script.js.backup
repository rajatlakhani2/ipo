                <h2>Add/Edit IPO</h2>
                <button class="close" onclick="closeModal('ipo-modal')">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form id="ipo-form">
                <input type="hidden" id="ipo-id">
                <div class="form-group">
                    <label>IPO Name *</label>
                    <input type="text" id="ipo-name" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Type</label>
                        <select id="ipo-type">
