<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hareshwar IPO Dashboard</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <div class="container">
        <header class="header">
            <h1><i class="fas fa-chart-line"></i> Hareshwar IPO Dashboard</h1>
            <p>Track investments, manage applications, and monitor profits across all accounts</p>
        </header>

        <!-- Dashboard Summary -->
        <div class="dashboard-summary" id="dashboard-summary">
            <div class="stat-card">
                <div class="stat-label">Total Investment</div>
                <div class="stat-value" id="total-invested">₹0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Profit</div>
                <div class="stat-value profit" id="total-profit">₹0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Applied</div>
                <div class="stat-value" id="total-applied">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Allotted</div>
                <div class="stat-value" id="total-allotted">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Payment Pending</div>
                <div class="stat-value pending" id="payment-pending">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Payment Received</div>
                <div class="stat-value" id="payment-received">0</div>
            </div>
        </div>

        <!-- IPO-wise Profit Summary -->
        <section class="section">
            <div class="section-header">
                <div class="section-title"><i class="fas fa-chart-pie"></i> IPO-wise Profit Summary</div>
            </div>

            <div class="table-container">
                <table id="ipo-profit-table">
                    <thead>
                        <tr>
                            <th>IPO Name</th>
                            <th>Allotted Applications</th>
                            <th>Total Profit</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated by JS -->
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Tabs -->
        <div class="tabs-container">
            <button class="tab-btn active" onclick="switchTab(this, 'tracking')">Application Tracking</button>
            <button class="tab-btn" onclick="switchTab(this, 'investors')">Investors</button>
            <button class="tab-btn" onclick="switchTab(this, 'ipos')">IPO List</button>
        </div>

        <!-- Application Tracking Tab -->
        <section class="section tab-content" id="tab-tracking">
            <div class="section-header">
                <div class="section-title"><i class="fas fa-list-check"></i> Application Tracking</div>
                <button class="btn btn-primary" onclick="openModal('application-modal')">
                    <i class="fas fa-plus"></i> Manual Application
                </button>
            </div>

            <div id="application-accordion">
                <!-- Populated by JS: IPO Accordions with Investor Grid -->
            </div>
        </section>

        <!-- Investor Management Tab -->
        <section class="section tab-content" id="tab-investors" style="display: none;">
            <div class="section-header">
                <div class="section-title"><i class="fas fa-users"></i> Investors</div>
                <div style="display: flex; gap: 1rem;">
                    <button class="btn btn-secondary" onclick="openModal('import-modal')">
                        <i class="fas fa-file-import"></i> Import Excel
                    </button>
                    <button class="btn btn-primary" onclick="openModal('investor-modal')">
                        <i class="fas fa-user-plus"></i> Add Investor
                    </button>
                </div>
            </div>

            <div class="table-container">
                <table id="investors-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>UPI ID</th>
                            <th>Family Group</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated by JS -->
                    </tbody>
                </table>
            </div>
        </section>

        <!-- IPO Management Tab -->
        <section class="section tab-content" id="tab-ipos" style="display: none;">
            <div class="section-header">
                <div class="section-title"><i class="fas fa-building"></i> IPO List</div>
                <button class="btn btn-primary" onclick="openModal('ipo-modal')">
                    <i class="fas fa-plus"></i> Add IPO
                </button>
            </div>

            <div class="table-container">
                <table id="ipos-table">
                    <thead>
                        <tr>
                            <th>IPO Name</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Shares/Lot</th>
                            <th>Buy Price</th>
                            <th>Sell Price</th>
                            <th>Profit/Lot</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated by JS -->
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <!-- Modals -->

    <!-- Investor Modal -->
    <div class="modal" id="investor-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Add Investor</h3>
                <button class="close-btn" onclick="closeModal('investor-modal')">&times;</button>
            </div>
            <form id="investor-form">
                <input type="hidden" id="investor-id">
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" id="investor-name" required>
                </div>
                <div class="form-group">
                    <label class="form-label">UPI ID</label>
                    <input type="text" class="form-control" id="investor-upi">
                </div>
                <div class="form-group">
                    <label class="form-label">Family Group</label>
                    <select class="form-control" id="investor-group">
                        <option value="Lakhani">Lakhani</option>
                        <option value="Family">Family</option>
                        <option value="Friends">Friends</option>
                        <option value="Relatives">Relatives</option>
                        <option value="Self">Self</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                        onclick="closeModal('investor-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Investor</button>
                </div>
            </form>
        </div>
    </div>

    <!-- IPO Modal -->
    <div class="modal" id="ipo-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Add IPO</h3>
                <button class="close-btn" onclick="closeModal('ipo-modal')">&times;</button>
            </div>
            <form id="ipo-form">
                <input type="hidden" id="ipo-id">
                <div class="form-group">
                    <label class="form-label">IPO Name</label>
                    <input type="text" class="form-control" id="ipo-name" required>
                </div>
                <div class="form-group">
                    <label class="form-label">IPO Type</label>
                    <select class="form-control" id="ipo-type">
                        <option value="Mainboard">Mainboard</option>
                        <option value="SME">SME</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select class="form-control" id="ipo-status">
                        <option value="Open">Open</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">IPO Date</label>
                    <input type="date" class="form-control" id="ipo-date">
                </div>
                <div class="form-group">
                    <label class="form-label">Listing Date</label>
                    <input type="date" class="form-control" id="ipo-listing-date">
                </div>
                <div class="form-group">
                    <label class="form-label">Shares per Lot</label>
                    <input type="number" class="form-control" id="ipo-shares" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Purchase Price (per share)</label>
                    <input type="number" step="0.01" class="form-control" id="ipo-buy-price" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Sale Price (per share)</label>
                    <input type="number" step="0.01" class="form-control" id="ipo-sell-price"
                        placeholder="Leave empty if not sold">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('ipo-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save IPO</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Application Modal -->
    <div class="modal" id="application-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">New Application</h3>
                <button class="close-btn" onclick="closeModal('application-modal')">&times;</button>
            </div>
            <form id="application-form">
                <input type="hidden" id="application-id">
                <div class="form-group">
                    <label class="form-label">Investor</label>
                    <select class="form-control" id="app-investor" required>
                        <!-- Populated by JS -->
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">IPO</label>
                    <select class="form-control" id="app-ipo" required>
                        <!-- Populated by JS -->
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Amount</label>
                    <input type="number" class="form-control" id="app-amount" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select class="form-control" id="app-status">
                        <option value="Applied">Applied</option>
                        <option value="Allotted">Allotted</option>
                        <option value="Not Allotted">Not Allotted</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Payment Status</label>
                    <select class="form-control" id="app-payment">
                        <option value="Pending">Pending</option>
                        <option value="Received">Received</option>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                        onclick="closeModal('application-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Application</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Import Modal -->
    <div class="modal" id="import-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Import Investors</h3>
                <button class="close-btn" onclick="closeModal('import-modal')">&times;</button>
            </div>
            <form id="import-form">
                <div class="form-group">
                    <label class="form-label">Excel File</label>
                    <input type="file" class="form-control" id="import-file" accept=".xlsx,.xls" required>
                </div>
                <div class="form-group">
                    <p style="color: var(--text-muted); font-size: 0.9rem;">
                        Download the <a href="#" onclick="downloadTemplate(event)"
                            style="color: var(--neon-blue);">template here</a>.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('import-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Import</button>
                </div>
            </form>
        </div>
    </div>

    <script src="script.js"></script>
</body>

</html>