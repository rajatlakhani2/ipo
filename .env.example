# Core — LIVE (ipo.kuhu.org.in): set these in cPanel Environment variables, NOT in git
SECRET_KEY=generate-a-long-random-string
APP_BASE_URL=https://ipo.kuhu.org.in
CORS_ORIGINS=https://ipo.kuhu.org.in
DISABLE_BACKGROUND_JOBS=true

# Local dev overrides
# APP_BASE_URL=http://localhost:5001
PORT=5001
APP_PORT=5001
HTTP_PORT=80

# PostgreSQL (Docker Compose)
POSTGRES_USER=ipo
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=ipo_control
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://ipo:password@localhost:5432/ipo_control

# Email verification (set true in production)
REQUIRE_EMAIL_VERIFICATION=false

# SMTP (Gmail, SendGrid, Amazon SES, etc.)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=true
MAIL_FROM=IPO Control <noreply@yourdomain.com>

# Stripe Pro subscription
# Create Product + recurring Price in Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# JWT session length (hours)
JWT_EXPIRY_HOURS=168

# Zerodha Kite Connect — https://developers.kite.trade/
# Redirect URL in Kite app must match KITE_REDIRECT_URL (default: APP_BASE_URL/broker/zerodha/callback)
KITE_API_KEY=
KITE_API_SECRET=
# LIVE: https://ipo.kuhu.org.in/broker/zerodha/callback
KITE_REDIRECT_URL=https://ipo.kuhu.org.in/broker/zerodha/callback

# Live price feed: nse (default) | upstox | dhan
PRICE_FEED_PROVIDER=nse

# Upstox WebSocket — live LTP (optional, Layer 2)
# UPSTOX_API_KEY=
# UPSTOX_API_SECRET=
# UPSTOX_ACCESS_TOKEN=
# UPSTOX_REDIRECT_URL=https://ipo.kuhu.org.in/broker/upstox/callback

# Dhan WebSocket — live LTP (optional, Layer 2)
# DHAN_CLIENT_ID=
# DHAN_ACCESS_TOKEN=
