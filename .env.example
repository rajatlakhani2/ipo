# Core
SECRET_KEY=generate-a-long-random-string
APP_BASE_URL=http://localhost:5001
PORT=5001
APP_PORT=5001
HTTP_PORT=80
CORS_ORIGINS=*

# PostgreSQL (Docker Compose)
POSTGRES_USER=ipo
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=ipo_control
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://ipo:password@localhost:5432/ipo_control

# Email verification (set true in production)
REQUIRE_EMAIL_VERIFICATION=false

# SMTP (Gmail, SendGrid, Amazon SES, etc.)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=true
MAIL_FROM=IPO Control <noreply@yourdomain.com>

# Stripe Pro subscription
# Create Product + recurring Price in Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# JWT session length (hours)
JWT_EXPIRY_HOURS=168

# Zerodha Kite Connect — https://developers.kite.trade/
# Redirect URL in Kite app must match KITE_REDIRECT_URL (default: APP_BASE_URL/broker/zerodha/callback)
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:5001/broker/zerodha/callback
